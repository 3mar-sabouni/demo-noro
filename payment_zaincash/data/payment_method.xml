<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate='1'>
        <record id="payment_method_zain_cash" model="payment.method">
            <field name="name">Zain Cash</field>
            <field name="code">zain_cash</field>
            <field name="image" type="base64" file="payment_zaincash/static/description/zain-cash.png"/>
            <field name="provider_ids" eval="[(4, ref('payment_zaincash.payment_provider_zain_cash'))]"/>
            <field name="supported_currency_ids" eval="[(4, ref('base.IQD'))]"/>
        </record>

        <record id="account_payment_method_zain_cash" model="account.payment.method">
            <field name="name">Zain Cash</field>
            <field name="code">zain_cash</field>
            <field name="payment_type">inbound</field>
        </record>
    </data>
</odoo>