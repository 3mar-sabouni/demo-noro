<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled Action -->
        <record id="ir_cron_auto_cancel_expired_pending_transactions" model="ir.cron">
            <field name="name">Payment: Cancel Expired Pending Transactions</field>
            <field name="model_id" ref="payment.model_payment_transaction"/>
            <field name="state">code</field>
            <field name="code">model._auto_cancel_expired_pending_transactions()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>