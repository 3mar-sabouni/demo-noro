<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate='1'>
        <record id="payment_method_qicard" model="payment.method">
            <field name="name">QiCard</field>
            <field name="code">qicard</field>
            <field name="support_refund">partial</field>
            <field name="image" type="base64" file="payment_qicard/static/description/qicard.png"/>
            <field name="provider_ids" eval="[(4, ref('payment_qicard.payment_provider_qicard'))]"/>
            <field name="supported_currency_ids" eval="[(4, ref('base.IQD'))]"/>
            <!-- <field name="countries_ids" eval="[(5, 0, 0)]"/>  -->
        </record>
        <record id="account_payment_method_qicard" model="account.payment.method">
            <field name="name">QiCard</field>
            <field name="code">qicard</field>
            <field name="payment_type">inbound</field>
        </record>
    </data>
</odoo>